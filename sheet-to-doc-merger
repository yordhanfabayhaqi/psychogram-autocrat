    .addItem('🔁 Force re-generate selected row', 'forceRegenerateSelectedRow')
    .addSeparator()
    .addItem('⚡ Install auto-trigger (merge when trigger column = YES)', 'installOnEditTrigger')
    .addItem('🧹 Uninstall auto-trigger', 'uninstallOnEditTrigger')
    .addToUi();

  SpreadsheetApp.getUi()
    .createMenu('⚙️ Setup')
    .addItem('🚀 Run setup wizard (all settings)', 'runSetupWizard')
