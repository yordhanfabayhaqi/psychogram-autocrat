function extractDriveId_(input) {
  // Accepts a Doc link, folder link, or raw ID
  const m = input.match(/[-\w]{25,}/);
  return m ? m[0] : null;
}


// ─────────────────────── ENTRY POINTS ───────────────────────
function generateAllPending() {
  const ui = SpreadsheetApp.getUi();
  const ctx = buildContext_();

  const pending = [];
  for (let r = 0; r < ctx.data.length; r++) {
    const trigger = String(ctx.data[r][ctx.col.trigger] || '').trim().toUpperCase();
    const status  = String(ctx.data[r][ctx.col.status]  || '').trim();
    if (trigger !== 'YES') continue;
    if (status.startsWith('Document successfully')) continue;
    pending.push({ r: r, rowIdx: ctx.cfg.HEADER_ROW + 1 + r, name: getDisplayName_(ctx, r) });
  }

  if (pending.length === 0) {
    ui.alert('No rows to process.\n\nMake sure the "' + ctx.cfg.COL_TRIGGER + '" column is set to YES and the merge status is still empty.');
    return;
  }

  // ★ CONFIRMATION: show the names before anything is created
  const list = pending.map((p, i) => (i + 1) + '. ' + p.name + ' (row ' + p.rowIdx + ')').join('\n');
  const confirm = ui.alert(
    'Confirm — ' + pending.length + ' document(s) will be created',
    'Documents will be generated for:\n\n' + list + '\n\nDoes this match your intent? Proceed?',
    ui.ButtonSet.YES_NO);

  if (confirm !== ui.Button.YES) {
    SpreadsheetApp.getActiveSpreadsheet().toast('Cancelled. No documents were created.', 'Merge Creator', 5);
    return;
  }

  let ok = 0, fail = 0;
  pending.forEach(p => {
    try {
      mergeRow_(ctx, p.r, p.rowIdx);
      ok++;
    } catch (e) {
      ctx.sheet.getRange(p.rowIdx, ctx.col.status + 1)
        .setValue('FAILED: ' + e.message + ' (' + nowStamp_() + ')');
      fail++;
    }
  });

  SpreadsheetApp.getActiveSpreadsheet().toast('Done. Success: ' + ok + ' | Failed: ' + fail, 'Merge Creator', 10);
}

function forceRegenerateSelectedRow() {
  const ui = SpreadsheetApp.getUi();
  const ctx = buildContext_();
  const rowIdx = ctx.sheet.getActiveCell().getRow();
  if (rowIdx <= ctx.cfg.HEADER_ROW) { ui.alert('Select a cell in a data row first (not the header).'); return; }

  const r = rowIdx - ctx.cfg.HEADER_ROW - 1;
  if (r < 0 || r >= ctx.data.length) { ui.alert('This row has no data.'); return; }

  const name = getDisplayName_(ctx, r);
  const confirm = ui.alert(
    'Confirm re-generate',
    'A document will be (re)generated for:\n\n' + name + ' (row ' + rowIdx + ')\n\nProceed?',
    ui.ButtonSet.YES_NO);
  if (confirm !== ui.Button.YES) return;

  try {
    mergeRow_(ctx, r, rowIdx);
    SpreadsheetApp.getActiveSpreadsheet().toast('Document for ' + name + ' generated.', 'Merge Creator', 5);
  } catch (e) {
    ctx.sheet.getRange(rowIdx, ctx.col.status + 1)
      .setValue('FAILED: ' + e.message + ' (' + nowStamp_() + ')');
    ui.alert('Failed: ' + e.message);
  }
}


// ─────────────────── AUTO-TRIGGER (OPTIONAL) ───────────────────
function installOnEditTrigger() {
  uninstallOnEditTrigger();
  ScriptApp.newTrigger('handleEdit_')
    .forSpreadsheet(SpreadsheetApp.getActiveSpreadsheet())
    .onEdit()
    .create();
  SpreadsheetApp.getActiveSpreadsheet().toast('Auto-trigger installed. Set the trigger column to YES → confirmation → merge.', 'Merge Creator', 8);
}

function uninstallOnEditTrigger() {
  ScriptApp.getProjectTriggers()
    .filter(t => t.getHandlerFunction() === 'handleEdit_')
    .forEach(t => ScriptApp.deleteTrigger(t));
}

function handleEdit_(e) {
  try {
    if (!e || !e.range) return;
    const cfg = getConfig_();
    const sheet = e.range.getSheet();
    if (sheet.getName() !== cfg.SHEET_NAME) return;

    const ctx = buildContext_();
    if (e.range.getColumn() - 1 !== ctx.col.trigger) return;

    const rowIdx = e.range.getRow();
    if (rowIdx <= ctx.cfg.HEADER_ROW) return;

    const val = String(e.value || '').trim().toUpperCase();
    if (val !== 'YES') return;

    const r = rowIdx - ctx.cfg.HEADER_ROW - 1;
    const status = String(ctx.data[r][ctx.col.status] || '').trim();
    if (status.startsWith('Document successfully')) return;

    // ★ Confirmation here too, for consistency
    const name = getDisplayName_(ctx, r);
    const ui = SpreadsheetApp.getUi();
    const confirm = ui.alert(
      'Confirm — 1 document will be created',
      'A document will be generated for:\n\n' + name + ' (row ' + rowIdx + ')\n\nProceed?',
      ui.ButtonSet.YES_NO);
    if (confirm !== ui.Button.YES) return;

    mergeRow_(ctx, r, rowIdx);
    SpreadsheetApp.getActiveSpreadsheet().toast('Document for ' + name + ' created.', 'Merge Creator', 5);
  } catch (err) {
    console.error('handleEdit_ error: ' + err.message);
  }
}


// ─────────────────────── CORE MERGE ───────────────────────
function mergeRow_(ctx, r, rowIdx) {
  const cfg = ctx.cfg;
  if (!cfg.TEMPLATE_DOC_ID) throw new Error('Template not set. Run ⚙️ Setup → Set template Doc.');

  const rowVals = ctx.data[r];
  const resolve = makeResolver_(ctx.headers, rowVals, cfg.ALIASES);

  const fileName = replacePlaceholdersInString_(cfg.FILE_NAME_PATTERN, resolve)
    .replace(/[\/\\:*?"<>|]/g, '-');

  const templateFile = DriveApp.getFileById(cfg.TEMPLATE_DOC_ID);
  const folder = cfg.OUTPUT_FOLDER_ID
    ? DriveApp.getFolderById(cfg.OUTPUT_FOLDER_ID)
    : (templateFile.getParents().hasNext() ? templateFile.getParents().next() : DriveApp.getRootFolder());

  // 1. Copy template → merged GOOGLE DOC
  const docCopy = templateFile.makeCopy(fileName, folder);
  const doc = DocumentApp.openById(docCopy.getId());

  // 2. Replace every <<...>> in body, header, footer
  const sections = [doc.getBody(), doc.getHeader(), doc.getFooter()].filter(Boolean);
  const unresolved = [];
  sections.forEach(section => {
    extractTags_(section.getText()).forEach(tag => {
      const val = resolve(tag);
      if (val === null) unresolved.push(tag);
      section.replaceText(escapeRegex_('<<' + tag + '>>'), val === null ? '' : escapeReplacement_(val));
    });
  });
  doc.saveAndClose();

  // 3. Export PDF
  const pdfBlob = DriveApp.getFileById(docCopy.getId()).getAs('application/pdf').setName(fileName + '.pdf');
  const pdfFile = folder.createFile(pdfBlob);

  // 4. Write results back:
  //    ID column = PDF ID | URL column = PDF URL | Link column = hyperlink to Google Doc | Status
  const status = 'Document successfully created ' + nowStamp_() +
    (unresolved.length ? ' | Unresolved tags: ' + unresolved.join(', ') : '');

  ctx.sheet.getRange(rowIdx, ctx.col.docId  + 1).setValue(pdfFile.getId());
  ctx.sheet.getRange(rowIdx, ctx.col.docUrl + 1).setValue(pdfFile.getUrl());
  ctx.sheet.getRange(rowIdx, ctx.col.link   + 1)
    .setFormula('=HYPERLINK("' + docCopy.getUrl() + '","' + fileName.replace(/"/g, '""') + '")');
  ctx.sheet.getRange(rowIdx, ctx.col.status + 1).setValue(status);
}


// ───────────────── PLACEHOLDER RESOLUTION ─────────────────
function makeResolver_(headers, rowVals, aliases) {
  const normHeaders = headers.map(h => norm_(h));
  const normAliases = {};
  Object.keys(aliases || {}).forEach(k => { normAliases[norm_(k)] = aliases[k]; });

  return function resolve(tag) {
    let key = norm_(tag);
    if (normAliases[key]) key = norm_(normAliases[key]);

    let i = normHeaders.indexOf(key);
    if (i !== -1) return String(rowVals[i]);

    i = normHeaders.findIndex(h => h.startsWith(key));
    if (i !== -1) return String(rowVals[i]);

    i = normHeaders.findIndex(h => key.startsWith(h) || h.includes(key));
    if (i !== -1) return String(rowVals[i]);

    return null;
  };
}

function replacePlaceholdersInString_(str, resolve) {
  return str.replace(/<<([^>]+)>>/g, (m, tag) => {
    const v = resolve(tag.trim());
    return v === null ? '' : v;
  });
}

function extractTags_(text) {
  const tags = new Set();
  const re = /<<([^>]+)>>/g;
  let m;
  while ((m = re.exec(text)) !== null) tags.add(m[1].trim());
  return [...tags];
}


// ───────────────────── HELPERS ─────────────────────
function buildContext_() {
  const cfg = getConfig_();
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(cfg.SHEET_NAME);
  if (!sheet) throw new Error('Sheet "' + cfg.SHEET_NAME + '" not found. Run ⚙️ Setup → Set sheet name.');

  const lastRow = sheet.getLastRow();
  const lastCol = sheet.getLastColumn();
  const headers = sheet.getRange(cfg.HEADER_ROW, 1, 1, lastCol).getDisplayValues()[0];
  const data = lastRow > cfg.HEADER_ROW
    ? sheet.getRange(cfg.HEADER_ROW + 1, 1, lastRow - cfg.HEADER_ROW, lastCol).getDisplayValues()
    : [];

  const findCol = (name) => {
    const key = norm_(name);
    let i = headers.findIndex(h => norm_(h) === key);
    if (i === -1) i = headers.findIndex(h => norm_(h).startsWith(key));
    if (i === -1) throw new Error('Column "' + name + '" not found in headers. Run ⚙️ Setup → Set column headers.');
    return i; // 0-based
  };

  return {
    cfg, sheet, headers, data,
    col: {
      trigger: findCol(cfg.COL_TRIGGER),
      docId:   findCol(cfg.COL_DOC_ID),
      docUrl:  findCol(cfg.COL_DOC_URL),
      link:    findCol(cfg.COL_LINK),
      status:  findCol(cfg.COL_STATUS),
    },
  };
}

function getDisplayName_(ctx, r) {
  const key = norm_(ctx.cfg.COL_NAME);
  const i = ctx.headers.findIndex(h => norm_(h) === key || norm_(h).startsWith(key));
  const name = i !== -1 ? String(ctx.data[r][i] || '').trim() : '';
  return name || '(name empty — row ' + (ctx.cfg.HEADER_ROW + 1 + r) + ')';
}

function norm_(s) {
  return String(s || '').replace(/\s+/g, ' ').trim().toLowerCase();
}

function escapeRegex_(s) {
  return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
}

function escapeReplacement_(s) {
  return String(s).replace(/\$/g, '\\$');
}

function nowStamp_() {
  return Utilities.formatDate(new Date(), Session.getScriptTimeZone(), 'dd/MM/yyyy HH:mm:ss');
}
