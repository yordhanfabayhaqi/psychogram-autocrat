// ─────────────────────── SETUP MENU ACTIONS ───────────────────────
function runSetupWizard() {
  setTemplateViaMenu();
  setFolderViaMenu();
  setSheetViaMenu();
  setColumnsViaMenu();
  showActiveConfig();
}

function setTemplateViaMenu() {
  const ui = SpreadsheetApp.getUi();
  const cfg = getConfig_();

  let currentInfo = '(not set)';
  if (cfg.TEMPLATE_DOC_ID) {
    try {
      const f = DriveApp.getFileById(cfg.TEMPLATE_DOC_ID);
      currentInfo = f.getName() + '\nhttps://docs.google.com/document/d/' + cfg.TEMPLATE_DOC_ID + '/edit';
    } catch (e) { currentInfo = '(saved but not accessible)'; }
  }

  const resp = ui.prompt(
    '📄 Set Template Doc',
    'Current ACTIVE template:\n' + currentInfo + '\n\n' +
    'Paste the link of the NEW Google Doc template below.\n' +
    '(Leave empty & click OK to only view, without changing.)',
    ui.ButtonSet.OK_CANCEL);

  if (resp.getSelectedButton() !== ui.Button.OK) return;
  const input = resp.getResponseText().trim();
  if (!input) return;

  const newId = extractDriveId_(input);
  if (!newId) { ui.alert('Invalid link. Make sure it is a Google Doc link.'); return; }

  let newName;
  try {
    newName = DocumentApp.openById(newId).getName();
  } catch (e) {
    ui.alert('Could not open that file as a Google Doc.\nCheck access/link.\n\nError: ' + e.message);
    return;
  }

  const confirm = ui.alert(
    'Confirm template change',
    'The merge template will be changed to:\n\n"' + newName + '"\n' +
    'https://docs.google.com/document/d/' + newId + '/edit\n\n' +
    'All merges AFTER this will use that template. Proceed?',
    ui.ButtonSet.YES_NO);
  if (confirm !== ui.Button.YES) { ui.alert('Cancelled. Template unchanged.'); return; }

  saveConfig_('TEMPLATE_DOC_ID', newId);
  ui.alert('✅ Template changed to: "' + newName + '"');
}

function setFolderViaMenu() {
  const ui = SpreadsheetApp.getUi();
  const cfg = getConfig_();

  let currentInfo = '(default: same folder as the template)';
  if (cfg.OUTPUT_FOLDER_ID) {
    try {
      const f = DriveApp.getFolderById(cfg.OUTPUT_FOLDER_ID);
      currentInfo = f.getName() + '\nhttps://drive.google.com/drive/folders/' + cfg.OUTPUT_FOLDER_ID;
    } catch (e) { currentInfo = '(saved but not accessible)'; }
  }

  const resp = ui.prompt(
    '📁 Set Output Folder',
    'Current ACTIVE output folder:\n' + currentInfo + '\n\n' +
    'Paste the link of the NEW Google Drive folder below.\n' +
    'Type RESET to return to the default (template folder).\n' +
    '(Leave empty & click OK to only view.)',
    ui.ButtonSet.OK_CANCEL);

  if (resp.getSelectedButton() !== ui.Button.OK) return;
  const input = resp.getResponseText().trim();
  if (!input) return;

  if (input.toUpperCase() === 'RESET') {
    const confirmReset = ui.alert('Confirm', 'Reset output folder to default (same folder as template)?', ui.ButtonSet.YES_NO);
    if (confirmReset === ui.Button.YES) {
      PropertiesService.getScriptProperties().deleteProperty(CONFIG_KEYS.OUTPUT_FOLDER_ID);
      ui.alert('✅ Output folder reset to default.');
    }
    return;
  }

  const newId = extractDriveId_(input);
  if (!newId) { ui.alert('Invalid link. Make sure it is a Drive folder link.'); return; }

  let newName;
  try {
    newName = DriveApp.getFolderById(newId).getName();
  } catch (e) {
    ui.alert('Could not open that folder.\nCheck access/link.\n\nError: ' + e.message);
    return;
  }

  const confirm = ui.alert(
    'Confirm output folder change',
    'All merge output (Doc + PDF) AFTER this will be saved to:\n\n"' + newName + '"\n' +
    'https://drive.google.com/drive/folders/' + newId + '\n\nProceed?',
    ui.ButtonSet.YES_NO);
  if (confirm !== ui.Button.YES) { ui.alert('Cancelled. Folder unchanged.'); return; }

  saveConfig_('OUTPUT_FOLDER_ID', newId);
  ui.alert('✅ Output folder changed to: "' + newName + '"');
}

function setSheetViaMenu() {
  const ui = SpreadsheetApp.getUi();
  const cfg = getConfig_();

  const s = ui.prompt('📊 Sheet name',
    'Current: "' + cfg.SHEET_NAME + '"\n\nEnter the name of the sheet (tab) containing your data.\n(Leave empty to keep.)',
    ui.ButtonSet.OK_CANCEL);
  if (s.getSelectedButton() !== ui.Button.OK) return;
  if (s.getResponseText().trim()) saveConfig_('SHEET_NAME', s.getResponseText().trim());

  const h = ui.prompt('📊 Header row',
    'Current: row ' + cfg.HEADER_ROW + '\n\nEnter the row number that contains your column headers.\n(Leave empty to keep.)',
    ui.ButtonSet.OK_CANCEL);
  if (h.getSelectedButton() !== ui.Button.OK) return;
  const hv = parseInt(h.getResponseText().trim(), 10);
  if (hv > 0) saveConfig_('HEADER_ROW', hv);
}

function setColumnsViaMenu() {
  const ui = SpreadsheetApp.getUi();
  const cfg = getConfig_();
  const fields = [
    ['COL_TRIGGER', 'Trigger column header (set to YES to merge a row)', cfg.COL_TRIGGER],
    ['COL_DOC_ID',  'Output column header: merged file ID',              cfg.COL_DOC_ID],
    ['COL_DOC_URL', 'Output column header: merged file URL (PDF)',       cfg.COL_DOC_URL],
    ['COL_LINK',    'Output column header: hyperlink to merged Doc',     cfg.COL_LINK],
    ['COL_STATUS',  'Output column header: merge status',                cfg.COL_STATUS],
    ['COL_NAME',    'Column header used as the display name in dialogs', cfg.COL_NAME],
  ];
  for (const [key, label, current] of fields) {
    const r = ui.prompt('🏷️ ' + label, 'Current: "' + current + '"\n(Leave empty to keep.)', ui.ButtonSet.OK_CANCEL);
    if (r.getSelectedButton() !== ui.Button.OK) return;
    if (r.getResponseText().trim()) saveConfig_(key, r.getResponseText().trim());
  }
}

function setAliasesViaMenu() {
  const ui = SpreadsheetApp.getUi();
  const cfg = getConfig_();
  const r = ui.prompt('🔤 Placeholder aliases (JSON)',
    'Maps short template tags to full header names.\n' +
    'Current: ' + cfg.ALIASES_JSON + '\n\n' +
    'Example: {"name":"Candidate Name","score":"Total Score"}\n(Leave empty to keep.)',
