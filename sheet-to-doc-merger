 * Sheet-to-Doc Merge Creator
 * 100% AI-generated, 100% human-directed.
 * Directed and iterated by Yordhan Fitrians Akhmad B. based on real HR pain points —
 * refined repeatedly for business fit, user experience, and workflow comfort.
 * Published as a generic, reusable template. Configure everything via the ⚙️ Setup menu.
 */

/*******************************************************************************
 * SHEET-TO-DOC MERGE CREATOR (Autocrat-style mail merge, public template)
 *
 * WHAT IT DOES
 *  1. Reads rows from a Google Sheet.
 *  2. When the trigger column (e.g. "Create Document?") is set to YES and the
 *     row has not been merged yet, it copies a Google Doc template, replaces
 *     every <<placeholder>> with the matching column value, and exports a PDF.
 *  3. Writes the merge results back to four output columns
 *     (Merged Doc ID / Merged Doc URL / Link to merged Doc / Merge Status).
 *
 * PLACEHOLDER RESOLUTION
 *  <<Tags>> in the Doc template are matched to SHEET HEADER NAMES
 *  (exact → prefix → contains, case-insensitive, whitespace-normalized),
 *  so inserting/removing columns is safe. Optional aliases map short tags
 *  (e.g. <<Name>>) to longer headers (e.g. "Candidate Name").
 *
 * ZERO HARDCODED IDS
 *  All IDs, sheet names, and column headers are entered once through the
 *  ⚙️ Setup menu and stored in Script Properties (PropertiesService).
 *  Nothing sensitive lives in this file.
 *
 * ─────────────────────────────────────────────────────────────────────────────
 * EXAMPLE SHEET SCHEMA — DEMONSTRATION ONLY, NOT PRODUCTION.
 * The real header mapping must be supplied by whoever adapts this template.
 * Row 1 (headers), data from row 2:
 *
 *   | Timestamp | Candidate Name | Role              | Score | Assessment Summary |
 *   | 01/01/25  | Jane Example   | General Executive | 85    | Meets expectations |
 *
 *   ...plus the control columns (anywhere in the sheet):
 *   | Create Document? | Merged Doc ID | Merged Doc URL | Link to merged Doc | Document Merge Status |
 *
 * A matching Doc template would contain e.g.:
 *   "Candidate: <<Candidate Name>> — Role: <<Role>> — Score: <<Score>>"
 * ─────────────────────────────────────────────────────────────────────────────
 ******************************************************************************/


// ═══════════════════════ CONFIG LAYER (Script Properties) ═══════════════════════
// No real IDs or names below — these are neutral defaults a new user overrides
// via the ⚙️ Setup menu. Values are stored with PropertiesService.

const CONFIG_KEYS = {
  TEMPLATE_DOC_ID:  'MERGE_TEMPLATE_DOC_ID',
  OUTPUT_FOLDER_ID: 'MERGE_OUTPUT_FOLDER_ID',
  SHEET_NAME:       'MERGE_SHEET_NAME',
  HEADER_ROW:       'MERGE_HEADER_ROW',
  COL_TRIGGER:      'MERGE_COL_TRIGGER',
  COL_DOC_ID:       'MERGE_COL_DOC_ID',
  COL_DOC_URL:      'MERGE_COL_DOC_URL',
  COL_LINK:         'MERGE_COL_LINK',
  COL_STATUS:       'MERGE_COL_STATUS',
  COL_NAME:         'MERGE_COL_NAME',
  FILE_NAME_PATTERN:'MERGE_FILE_NAME_PATTERN',
  ALIASES_JSON:     'MERGE_ALIASES_JSON',
};

const CONFIG_DEFAULTS = {
  TEMPLATE_DOC_ID:  '',                       // required — set via ⚙️ Setup
  OUTPUT_FOLDER_ID: '',                       // empty = same folder as template
  SHEET_NAME:       'Sheet1',
  HEADER_ROW:       '1',
  COL_TRIGGER:      'Create Document?',
  COL_DOC_ID:       'Merged Doc ID',
  COL_DOC_URL:      'Merged Doc URL',
  COL_LINK:         'Link to merged Doc',
  COL_STATUS:       'Document Merge Status',
  COL_NAME:         'Candidate Name',         // used for confirmation dialogs & file names
  FILE_NAME_PATTERN:'Merged Document - <<Candidate Name>> - <<Timestamp>>',
  // Short-tag aliases → header names. JSON string. Demonstration values only.
  ALIASES_JSON:     '{"name":"Candidate Name"}',
};

/** Read full config: Script Properties merged over defaults. */
function getConfig_() {
  const props = PropertiesService.getScriptProperties();
  const cfg = {};
  Object.keys(CONFIG_KEYS).forEach(k => {
    cfg[k] = props.getProperty(CONFIG_KEYS[k]) || CONFIG_DEFAULTS[k];
  });
  cfg.HEADER_ROW = parseInt(cfg.HEADER_ROW, 10) || 1;
  try { cfg.ALIASES = JSON.parse(cfg.ALIASES_JSON); } catch (e) { cfg.ALIASES = {}; }
  return cfg;
}

/** Write one config value to Script Properties. */
function saveConfig_(key, value) {
  PropertiesService.getScriptProperties().setProperty(CONFIG_KEYS[key], String(value));
}


// ─────────────────────────── MENU ───────────────────────────
function onOpen() {
  SpreadsheetApp.getUi()
    .createMenu('📄 Merge Creator')
