function showActiveConfig() {
  const ui = SpreadsheetApp.getUi();
  const cfg = getConfig_();

  let tplInfo = '(not set — run ⚙️ Setup)';
  if (cfg.TEMPLATE_DOC_ID) {
    try { tplInfo = DriveApp.getFileById(cfg.TEMPLATE_DOC_ID).getName(); }
    catch (e) { tplInfo = '(not accessible)'; }
  }

  let folderInfo = '(default: template folder)';
  if (cfg.OUTPUT_FOLDER_ID) {
    try { folderInfo = DriveApp.getFolderById(cfg.OUTPUT_FOLDER_ID).getName(); }
